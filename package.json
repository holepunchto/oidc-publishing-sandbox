{
  "name": "oidc-publishing-sandbox",
  "version": "1.0.7",
  "description": "Sandbox for testing OIDC publishing",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:bare && npm run test:node",
    "test:bare": "brittle-bare --coverage test.js",
    "test:node": "brittle-node --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/oidc-publishing-sandbox.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/oidc-publishing-sandbox/issues"
  },
  "homepage": "https://github.com/holepunchto/oidc-publishing-sandbox#readme",
  "devDependencies": {
    "brittle": "^3.19.1",
    "lunte": "^1.6.0",
    "prettier": "^3.4.2",
    "prettier-config-holepunch": "^1.0.0"
  }
}
